{
  "must_find": [
    {
      "id": "identity-absent-from-cache-key",
      "description": "Authenticated, per-user account pages are cached under a key derived only from path+query, with no user identity. The next requester of the same path is served the previous user's personalized page — cross-tenant bleed.",
      "match": {
        "seam_kind": "tenant_isolation",
        "blast_radius_min": "high",
        "all_of": [
          ["cache.?key", "keyed", "cache key"],
          ["no .{0,15}(user|identity|owner)", "without .{0,10}(user|identity)", "(not|never) .{0,15}(include|incorporat|scoped|keyed|wired|derived|based).{0,15}(user|identity)", "omits? .{0,15}(user|identity|owner)", "identity.?(free|less)", "missing .{0,10}(user|identity)", "not user-?scoped"]
        ]
      }
    },
    {
      "id": "cross-user-response-served",
      "description": "The consequence: one authenticated user's personalized response (billing/card data) is served to a different user.",
      "match": {
        "all_of": [
          ["another user", "other user", "different (user|requester)", "cross-?user", "cross-?tenant", "someone else", "next requester"],
          ["served", "returned", "sees", "receives", "exposed", "leak", "bleed"]
        ]
      }
    }
  ],
  "must_not_claim": [
    {
      "id": "caching-authenticated-is-inherently-wrong",
      "description": "BITE-RISK. Caching authenticated responses is legitimate when the key is user-scoped. A review must not claim caching per-user responses is inherently the defect.",
      "match": {
        "asserted_claim": {
          "subject": ["caching authenticated", "cache authenticated", "caching per-user", "caching personalized", "authenticated, per-user", "per-user responses", "personalized responses"],
          "predicate": ["inherent", "inherently", "never", "should not", "wrong to cache", "must not cache"],
          "within": 50
        }
      }
    },
    {
      "id": "load-spike-is-the-bug",
      "description": "Traffic load revealed the bug; it was not the cause. A review must not attribute the defect to the spike/DoS.",
      "match": {
        "asserted_claim": {
          "subject": ["load", "spike", "traffic", "dos", "denial of service"],
          "predicate": ["cause", "caused by", "due to", "because of", "root cause", "the bug is", "triggered by"],
          "within": 50
        }
      }
    }
  ]
}
