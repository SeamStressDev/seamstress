{
  "name": "seamstress",
  "version": "0.1.0",
  "description": "Seam-scoped code review engine — disciplined cross-model judgment on high-risk code seams.",
  "type": "module",
  "private": true,
  "license": "AGPL-3.0-only",
  "engines": {
    "node": ">=22"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit && tsc --noEmit -p benchmark/tsconfig.json",
    "dev": "tsx src/index.ts",
    "smoke": "tsx src/index.ts",
    "review": "tsx src/review.ts",
    "detect": "tsx src/detect.ts",
    "map": "tsx src/map.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.69.0",
    "tsx": "^4.19.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
