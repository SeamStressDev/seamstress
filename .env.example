# SeamStress engine environment variables.
# Copy this file to `.env` and fill in real values. `.env` is gitignored — never commit it.

# Anthropic API key — used by the LLM client wrapper (src/llm/client.ts).
# Get one at https://console.anthropic.com/. Never log or hardcode this value.
ANTHROPIC_API_KEY=sk-ant-...
